# Cogworks webapp — local environment variables
# Copy to .env.local for local development. Do not commit .env.local.
# All variables are prefixed with VITE_ so Vite exposes them to client code.

# ninsys-api base URL.
# - Local dev: http://localhost:3001 (matches the default)
# - Leave unset in production builds — nginx handles proxying via relative paths.
# Used by:
#   - Vite dev server proxy target for /v2/cogworks/*
#   - OAuth redirect URL (browser redirects bypass the Vite proxy)
VITE_API_URL=http://localhost:3001

# Discord bot client ID, used to render the "Add to Server" invite link.
# Optional — the dashboard works without it, the invite button just won't appear.
# Find this in https://discord.com/developers/applications → your app → General Information
VITE_BOT_CLIENT_ID=
